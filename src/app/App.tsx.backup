              <div key={s.step} className="text-center">
                <div className="w-16 h-16 rounded-full flex items-center justify-center text-3xl mx-auto mb-4" style={{ backgroundColor: "rgba(255,255,255,0.1)" }}>{s.icon}</div>
                <div className="text-xs font-bold tracking-widest mb-2" style={{ color: "#8BC34A" }}>STEP {s.step}</div>
                <h3 className="text-white font-bold text-lg mb-2">{s.title}</h3>
                <p className="text-white/60 text-sm leading-relaxed">{s.desc}</p>
              </div>
            ))}

              <MessageCircle size={20} /> Order on WhatsApp
            </a>
            <a href="tel:9579702008" className="flex items-center gap-2 text-white font-semibold px-8 py-4 rounded-full text-base" style={{ backgroundColor: "rgba(255,255,255,0.14)" }}>
              <Phone size={18} /> Call 9579702008
            </a>
          </div>
